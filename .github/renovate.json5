{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    ":dependencyDashboard",
    ":separateMultipleMajorReleases",
  ],
  labels: ["dependencies", "renovate"],
  assignees: [],
  reviewers: [],
  automerge: true,
  platformAutomerge: true,
  ignoreDeps: [],
  packageRules: [
    {
      description: "Auto-merge patch and minor updates for Docker images",
      matchDatasources: ["docker"],
      matchUpdateTypes: ["patch", "minor"],
      automerge: true,
      schedule: ["before 9am on Monday"],
    },
    {
      description: "Auto-merge patch updates for all dependencies",
      matchUpdateTypes: ["patch"],
      automerge: true,
      schedule: ["at any time"],
    },
    {
      description: "Group Docker Compose dependencies",
      matchFileNames: ["docker-compose*.yml"],
      groupName: "Docker Compose",
      groupSlug: "docker-compose",
    },
    {
      description: "Group GitHub Actions dependencies",
      matchFileNames: [".github/workflows/*.yml"],
      groupName: "GitHub Actions",
      groupSlug: "github-actions",
    },
    {
      description: "Group PostgreSQL updates",
      matchPackageNames: ["postgres"],
      groupName: "PostgreSQL",
      groupSlug: "postgres",
    },
    {
      description: "Group SonarQube updates",
      matchPackageNames: ["sonarqube"],
      groupName: "SonarQube",
      groupSlug: "sonarqube",
    },
    {
      description: "Group Nginx updates",
      matchPackageNames: ["nginx"],
      groupName: "Nginx",
      groupSlug: "nginx",
    },
    {
      description: "Require approval for major updates",
      matchUpdateTypes: ["major"],
      automerge: false,
      approval: true,
      schedule: ["before 9am on Monday"],
    },
  ],
  prConcurrentLimit: 5,
  prHourlyLimit: 2,
  schedule: ["before 9am on Monday"],
  timezone: "UTC",
  dependencyDashboardTitle: "Renovate Dashboard",
  dependencyDashboardApproval: false,
  lockFileMaintenance: {
    enabled: true,
    automerge: true,
    schedule: ["before 9am on Monday"],
  },
  regexManagers: [
    {
      description: "Update SonarQube version in Dockerfile",
      fileMatch: ["Dockerfile.sonarqube"],
      matchStrings: ["FROM sonarqube:(?<currentValue>.*?)-community"],
      datasourceTemplate: "docker",
      depNameTemplate: "sonarqube",
    },
  ],
}
