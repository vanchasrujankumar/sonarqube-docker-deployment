# =============================================================================
# SonarQube Docker Deployment - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
# =============================================================================

# Deployment mode: dev | production
ENV_MODE=dev

# SonarQube
# ---------------------------------------------------------------------------
SONAR_VERSION=community
SONAR_IMAGE=sonarqube:community
SONAR_HTTP_PORT=9000
SONAR_WEB_CONTEXT=/

# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_TAG=17-alpine
POSTGRES_DB=sonarqube
POSTGRES_USER=sonarqube
# REQUIRED: Change this to a strong password before running
POSTGRES_PASSWORD=change_this_strong_password

# Nginx (production only)
# ---------------------------------------------------------------------------
NGINX_TAG=1.27-alpine
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# General
# ---------------------------------------------------------------------------
TZ=UTC
